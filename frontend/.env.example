EXPO_PUBLIC_API_URL=http://172.24.46.192:5000/api

# Firebase client config comes from Firebase Console > Project settings > Your apps > Web app.
# Do not paste the service account JSON here; that credential is backend-only.
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=safeguardher-28.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=safeguardher-28
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=safeguardher-28.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=YOUR_EXPO_GOOGLE_CLIENT_ID
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_GOOGLE_CLIENT_ID
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_GOOGLE_CLIENT_ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_GOOGLE_CLIENT_ID
# ============================================================
# BABY SCAN APP - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values

# Groq API
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_FALLBACK_MODEL=

# Firebase Configuration
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Option 1: paste the JSON on one line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"safeguardher-28","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
# Option 2: point to the downloaded JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Firebase Storage Bucket (e.g., your-project-id.appspot.com)
FIREBASE_STORAGE_BUCKET=safeguardher-28.appspot.com

# Server Port
PORT=3000
